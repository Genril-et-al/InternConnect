# Supabase — copy this file to .env.local and fill in your project's values.
# Find these in your Supabase dashboard: Project Settings > API.
# Both values below are safe to expose in the browser (they are NOT secrets).
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# The service_role key is a SECRET. Never put it in a VITE_ variable or the
# frontend. It belongs only in server-side code / Supabase secrets.
